<?xml version="1.0" encoding="UTF-8"?>
<project name="org.eclipse.equinox.p2.metadata.repository" default="default" basedir=".">

	<target name="default" description="Compile ant tasks" depends="checkSourceUpToDate" unless="jarUpToDate">
		<mkdir dir="${basedir}/ant_tasks" />
		<jar destfile="${basedir}/ant_tasks/metadataRepository-ant.jar" basedir="${basedir}/bin_ant"/>
	</target>

	<target name="checkSourceUpToDate">
		<uptodate property="jarUpToDate" targetfile="${basedir}/ant_tasks/metadataRepository-ant.jar">
			<srcfiles dir="${basedir}/src_ant" includes="**/*"/>
		</uptodate>
	</target>
</project>